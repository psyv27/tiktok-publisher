# TikTok API Credentials (optional - can be set in api_credentials.json)
TIKTOK_CLIENT_ID=your_client_id_here
TIKTOK_CLIENT_SECRET=your_client_secret_here
TIKTOK_REDIRECT_URI=https://oauth.pstmn.io/v1/callback

# YouTube API Key (for video downloads)
YOUTUBE_API_KEY=your_youtube_api_key_here

# Video Download Directory
VIDEO_DOWNLOAD_PATH=./downloads

# Other optional settings
DEBUG=false
LOG_LEVEL=INFO
